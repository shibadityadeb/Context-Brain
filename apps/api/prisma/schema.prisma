// Company Brain — Phase 0 core schema.
// Generic identity / tenancy / audit primitives only. Domain tables
// (meetings, documents, tasks, …) arrive in later phases as new models
// that reference these.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoleName {
  ADMIN
  MANAGER
  EMPLOYEE
  SERVICE
}

model User {
  id           String    @id @default(uuid()) @db.Uuid
  email        String    @unique
  // Null for Google OAuth accounts — the platform has no password login.
  passwordHash String?
  name         String
  role         RoleName  @default(EMPLOYEE)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?

  memberships Membership[]
  sessions    Session[]
  auditLogs   AuditLog[]
  apiKeys     APIKey[]

  folders          Folder[]
  tags             Tag[]
  knowledgeSources KnowledgeSource[]
  documents        Document[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([email])
  @@map("users")
}

model Organization {
  id   String @id @default(uuid()) @db.Uuid
  name String
  slug String @unique

  memberships Membership[]
  projects    Project[]
  apiKeys     APIKey[]
  auditLogs   AuditLog[]

  folders          Folder[]
  tags             Tag[]
  knowledgeSources KnowledgeSource[]
  documents        Document[]

  connectors     Connector[]
  connectorLinks OrganizationConnector[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("organizations")
}

model Project {
  id          String  @id @default(uuid()) @db.Uuid
  name        String
  description String?

  organizationId String       @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  folders          Folder[]
  knowledgeSources KnowledgeSource[]
  documents        Document[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([organizationId])
  @@map("projects")
}

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  name        RoleName @unique
  description String?
  // Permission strings, e.g. "project:manage". Future phases append their
  // own permissions without schema changes.
  permissions String[]

  memberships Membership[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("roles")
}

model Membership {
  id String @id @default(uuid()) @db.Uuid

  userId         String       @db.Uuid
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String       @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  roleId         String       @db.Uuid
  orgRole        Role         @relation(fields: [roleId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@map("memberships")
}

model Session {
  id String @id @default(uuid()) @db.Uuid

  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // SHA-256 hash of the refresh token — raw tokens are never stored.
  refreshTokenHash String    @unique
  userAgent        String?
  ipAddress        String?
  expiresAt        DateTime
  revokedAt        DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([userId])
  @@map("sessions")
}

model APIKey {
  id String @id @default(uuid()) @db.Uuid

  name       String
  // First characters of the key, shown in UIs for identification.
  prefix     String    @unique
  keyHash    String    @unique
  scopes     String[]
  lastUsedAt DateTime?
  expiresAt  DateTime?

  userId         String?       @db.Uuid
  user           User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  organizationId String?       @db.Uuid
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([organizationId])
  @@map("api_keys")
}

model AuditLog {
  id String @id @default(uuid()) @db.Uuid

  // e.g. "auth.login", "user.update" — namespaced per module.
  action     String
  resource   String?
  resourceId String? @db.Uuid
  metadata   Json?
  ipAddress  String?
  userAgent  String?

  actorId        String?       @db.Uuid
  actor          User?         @relation(fields: [actorId], references: [id], onDelete: SetNull)
  organizationId String?       @db.Uuid
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([actorId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

// ────────────────────────────────────────────────────────────────
// Phase 1 — Knowledge Brain
// Documents, versions, chunks, embeddings, folders, tags, sources
// and processing jobs. Every model carries organization scoping,
// optional project scoping, ownership and soft-delete + audit
// timestamps, matching the Phase 0 conventions.
// ────────────────────────────────────────────────────────────────

enum DocumentStatus {
  UPLOADED
  PROCESSING
  READY
  FAILED
  ARCHIVED
}

enum ProcessingStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum ProcessingStage {
  VALIDATE
  PARSE
  CLEAN
  CHUNK
  METADATA
  EMBED
  INDEX
  PERSIST
  COMPLETE
}

enum KnowledgeSourceType {
  UPLOAD
  API
  INTEGRATION
}

model Folder {
  id   String @id @default(uuid()) @db.Uuid
  name String

  parentId String?  @db.Uuid
  parent   Folder?  @relation("FolderTree", fields: [parentId], references: [id], onDelete: SetNull)
  children Folder[] @relation("FolderTree")

  organizationId String       @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  projectId      String?      @db.Uuid
  project        Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  ownerId        String?      @db.Uuid
  owner          User?        @relation(fields: [ownerId], references: [id], onDelete: SetNull)

  documents Document[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([organizationId])
  @@index([parentId])
  @@map("folders")
}

model Tag {
  id    String  @id @default(uuid()) @db.Uuid
  name  String
  slug  String
  color String?

  organizationId String       @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  ownerId        String?      @db.Uuid
  owner          User?        @relation(fields: [ownerId], references: [id], onDelete: SetNull)

  documents DocumentTag[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([organizationId, slug])
  @@map("tags")
}

model KnowledgeSource {
  id     String              @id @default(uuid()) @db.Uuid
  name   String
  type   KnowledgeSourceType @default(UPLOAD)
  // Source-specific configuration (e.g. integration credentials pointer).
  config Json?

  organizationId String       @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  projectId      String?      @db.Uuid
  project        Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  ownerId        String?      @db.Uuid
  owner          User?        @relation(fields: [ownerId], references: [id], onDelete: SetNull)

  documents Document[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([organizationId])
  @@map("knowledge_sources")
}

model Document {
  id          String  @id @default(uuid()) @db.Uuid
  title       String
  description String?

  fileName      String
  mimeType      String
  fileSizeBytes Int
  storageBucket String
  storageKey    String
  checksum      String?
  status        DocumentStatus @default(UPLOADED)
  language      String?
  // Extracted metadata: author, keywords, headings, sections, tables,
  // creationDate — schema-free so parsers can evolve.
  metadata      Json?

  currentVersion Int @default(1)

  folderId String?          @db.Uuid
  folder   Folder?          @relation(fields: [folderId], references: [id], onDelete: SetNull)
  sourceId String?          @db.Uuid
  source   KnowledgeSource? @relation(fields: [sourceId], references: [id], onDelete: SetNull)

  organizationId String       @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  projectId      String?      @db.Uuid
  project        Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  ownerId        String?      @db.Uuid
  owner          User?        @relation(fields: [ownerId], references: [id], onDelete: SetNull)

  versions          DocumentVersion[]
  chunks            Chunk[]
  embeddings        EmbeddingReference[]
  tags              DocumentTag[]
  processingJobs    ProcessingJob[]
  externalResources ExternalResource[]
  knowledgeObjects  KnowledgeObject[]    @relation("KnowledgeObjectSource")
  entityMentions    EntityMention[]      @relation("KnowledgeMentions")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([projectId])
  @@index([folderId])
  @@map("documents")
}

model DocumentVersion {
  id      String @id @default(uuid()) @db.Uuid
  version Int

  documentId String   @db.Uuid
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  storageKey    String
  fileSizeBytes Int
  checksum      String?
  // Parser output snapshot for this version (headings, sections, stats).
  metadata      Json?

  organizationId String @db.Uuid

  chunks Chunk[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([documentId, version])
  @@index([organizationId])
  @@map("document_versions")
}

model DocumentTag {
  documentId String   @db.Uuid
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  tagId      String   @db.Uuid
  tag        Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([documentId, tagId])
  @@map("document_tags")
}

model Chunk {
  id    String @id @default(uuid()) @db.Uuid
  index Int

  content     String  @db.Text
  tokenCount  Int
  heading     String?
  section     String?
  startOffset Int     @default(0)
  endOffset   Int     @default(0)
  metadata    Json?

  documentId String          @db.Uuid
  document   Document        @relation(fields: [documentId], references: [id], onDelete: Cascade)
  versionId  String          @db.Uuid
  version    DocumentVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  organizationId String @db.Uuid

  embedding EmbeddingReference?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([versionId, index])
  @@index([documentId])
  @@index([organizationId])
  @@map("chunks")
}

model EmbeddingReference {
  id String @id @default(uuid()) @db.Uuid

  chunkId    String   @unique @db.Uuid
  chunk      Chunk    @relation(fields: [chunkId], references: [id], onDelete: Cascade)
  documentId String   @db.Uuid
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  // Qdrant location + provenance of the vector.
  collection String
  pointId    String @db.Uuid
  provider   String
  model      String
  dimension  Int

  organizationId String @db.Uuid

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([documentId])
  @@index([organizationId])
  @@map("embedding_references")
}

model ProcessingJob {
  id String @id @default(uuid()) @db.Uuid

  documentId      String   @db.Uuid
  document        Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  documentVersion Int      @default(1)

  // Temporal linkage for observability.
  workflowId String
  runId      String?

  stage   ProcessingStage  @default(VALIDATE)
  status  ProcessingStatus @default(PENDING)
  attempt Int              @default(1)
  error   String?
  // Append-only stage log: [{stage, message, at}]
  logs    Json[]

  chunkCount     Int?
  embeddingCount Int?

  organizationId String @db.Uuid

  startedAt   DateTime?
  completedAt DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([documentId])
  @@index([organizationId, status])
  @@index([workflowId])
  @@map("processing_jobs")
}

// ────────────────────────────────────────────────────────────────
// Phase 1 — Knowledge Connector Platform
// Generic connector framework tables: one Connector row per linked
// external system (Google Workspace first; Slack/GitHub/Notion/… later),
// with credentials, sync jobs, cursors, discovered resources, changes,
// permissions, versions and an audit log. Organization scoping,
// soft delete and audit timestamps everywhere. Child tables carry
// organizationId as a plain scalar for isolation queries.
// ────────────────────────────────────────────────────────────────

enum ConnectorProvider {
  GOOGLE_WORKSPACE
  SLACK
  GITHUB
  NOTION
  CONFLUENCE
  MICROSOFT_365
  DROPBOX
  JIRA
  LINEAR
  SALESFORCE
}

enum ConnectorStatus {
  PENDING
  CONNECTED
  SYNCING
  ERROR
  DISCONNECTED
  REVOKED
}

enum CredentialStatus {
  ACTIVE
  EXPIRED
  REVOKED
}

enum SyncJobType {
  INITIAL
  INCREMENTAL
  DISCOVERY
  PERMISSION
  MANUAL
}

enum SyncJobStatus {
  PENDING
  RUNNING
  COMPLETED
  PARTIAL
  FAILED
  CANCELLED
}

enum ExternalResourceType {
  GOOGLE_DOC
  GOOGLE_SHEET
  GOOGLE_SLIDES
  PDF
  FOLDER
  DRIVE_FILE
  SHARED_DRIVE
  EMAIL
  EMAIL_THREAD
  CALENDAR
  CALENDAR_EVENT
  ATTACHMENT
  OTHER
}

enum ExternalResourceStatus {
  ACTIVE
  TRASHED
  DELETED
}

enum ChangeType {
  CREATED
  UPDATED
  DELETED
  PERMISSION_CHANGED
}

enum PermissionRole {
  OWNER
  EDITOR
  COMMENTER
  VIEWER
}

enum PrincipalType {
  USER
  GROUP
  DOMAIN
  ANYONE
}

enum ConnectorLogLevel {
  DEBUG
  INFO
  WARN
  ERROR
}

model Connector {
  id       String            @id @default(uuid()) @db.Uuid
  provider ConnectorProvider
  name     String
  status   ConnectorStatus   @default(PENDING)
  // Provider-specific, non-secret configuration (sync intervals, filters).
  config   Json?
  error    String?

  lastSyncAt DateTime?
  nextSyncAt DateTime?

  organizationId String       @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  ownerId        String?      @db.Uuid

  workspace     Workspace?
  credentials   OAuthCredential[]
  syncJobs      SyncJob[]
  syncCursors   SyncCursor[]
  resources     ExternalResource[]
  changes       ExternalChange[]
  logs          ConnectorLog[]
  organizations OrganizationConnector[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([organizationId, provider])
  @@index([organizationId, status])
  @@map("connectors")
}

model OrganizationConnector {
  id String @id @default(uuid()) @db.Uuid

  organizationId String       @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  connectorId    String       @db.Uuid
  connector      Connector    @relation(fields: [connectorId], references: [id], onDelete: Cascade)

  isEnabled Boolean         @default(true)
  // Per-organization overrides (which services to sync, schedules…).
  settings  Json?
  status    ConnectorStatus @default(PENDING)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([organizationId, connectorId])
  @@map("organization_connectors")
}

model Workspace {
  id String @id @default(uuid()) @db.Uuid

  connectorId String    @unique @db.Uuid
  connector   Connector @relation(fields: [connectorId], references: [id], onDelete: Cascade)

  // Provider-side identity: Google customer id, Slack team id, …
  externalId String?
  domain     String?
  name       String?
  adminEmail String?
  metadata   Json?
  status     ConnectorStatus @default(CONNECTED)

  organizationId String @db.Uuid

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([organizationId])
  @@index([domain])
  @@map("workspaces")
}

model OAuthCredential {
  id String @id @default(uuid()) @db.Uuid

  connectorId String    @db.Uuid
  connector   Connector @relation(fields: [connectorId], references: [id], onDelete: Cascade)

  // Account the grant belongs to (the connecting admin).
  userEmail             String?
  scopes                String[]
  // AES-256-GCM encrypted refresh token — never stored in plaintext,
  // never returned by any API.
  encryptedRefreshToken String
  accessTokenExpiresAt  DateTime?
  tokenType             String           @default("Bearer")
  status                CredentialStatus @default(ACTIVE)
  lastRefreshedAt       DateTime?

  organizationId String @db.Uuid

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([connectorId])
  @@index([organizationId])
  @@map("oauth_credentials")
}

model SyncJob {
  id String @id @default(uuid()) @db.Uuid

  connectorId String    @db.Uuid
  connector   Connector @relation(fields: [connectorId], references: [id], onDelete: Cascade)

  type    SyncJobType
  status  SyncJobStatus @default(PENDING)
  // Which provider service this job covers: drive, docs, gmail, calendar…
  service String?

  // Temporal linkage for observability.
  workflowId String
  runId      String?

  // Counters: {discovered, created, updated, deleted, permissions, errors}
  stats Json?
  error String?

  organizationId String @db.Uuid

  startedAt   DateTime?
  completedAt DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([connectorId, status])
  @@index([organizationId, createdAt])
  @@index([workflowId])
  @@map("sync_jobs")
}

model SyncCursor {
  id String @id @default(uuid()) @db.Uuid

  connectorId String    @db.Uuid
  connector   Connector @relation(fields: [connectorId], references: [id], onDelete: Cascade)

  // drive | gmail | calendar | permissions …
  service       String
  // Narrower scope inside a service (a shared drive id, a calendar id).
  resourceScope String          @default("")
  // Opaque provider cursor: Drive changes pageToken, Gmail historyId,
  // Calendar syncToken.
  cursor        String
  status        ConnectorStatus @default(CONNECTED)

  organizationId String @db.Uuid

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([connectorId, service, resourceScope])
  @@map("sync_cursors")
}

model ExternalResource {
  id String @id @default(uuid()) @db.Uuid

  connectorId String    @db.Uuid
  connector   Connector @relation(fields: [connectorId], references: [id], onDelete: Cascade)

  externalId String
  type       ExternalResourceType
  status     ExternalResourceStatus @default(ACTIVE)

  title             String?
  mimeType          String?
  url               String?
  ownerEmail        String?
  // Provider-side hierarchy (Drive parent folder id, Gmail thread id…).
  parentExternalId  String?
  driveId           String?
  sizeBytes         BigInt?
  checksum          String?
  version           String?
  externalCreatedAt DateTime?
  externalUpdatedAt DateTime?
  // Service-specific extras (labels, attendees, worksheet names, …).
  metadata          Json?

  organizationId String @db.Uuid

  // The knowledge Document created from this resource's exported content.
  documentId String?   @db.Uuid
  document   Document? @relation(fields: [documentId], references: [id], onDelete: SetNull)

  permissions  ResourcePermission[]
  versions     ResourceVersion[]
  changeEvents ExternalChange[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([connectorId, externalId])
  @@index([organizationId, type])
  @@index([connectorId, type])
  @@index([parentExternalId])
  @@map("external_resources")
}

model ExternalChange {
  id String @id @default(uuid()) @db.Uuid

  connectorId String            @db.Uuid
  connector   Connector         @relation(fields: [connectorId], references: [id], onDelete: Cascade)
  resourceId  String?           @db.Uuid
  resource    ExternalResource? @relation(fields: [resourceId], references: [id], onDelete: SetNull)

  externalId String
  service    String
  changeType ChangeType
  // Raw provider change payload for replay/debugging.
  payload    Json?

  occurredAt  DateTime  @default(now())
  processedAt DateTime?

  organizationId String @db.Uuid

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([connectorId, occurredAt])
  @@index([organizationId, changeType])
  @@map("external_changes")
}

model ResourcePermission {
  id String @id @default(uuid()) @db.Uuid

  resourceId String           @db.Uuid
  resource   ExternalResource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  externalPermissionId String?
  principalType        PrincipalType
  // Email of the user/group; null for DOMAIN/ANYONE grants.
  principalEmail       String?
  domain               String?
  role                 PermissionRole
  status               ExternalResourceStatus @default(ACTIVE)

  organizationId String @db.Uuid

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([resourceId])
  @@index([organizationId, principalEmail])
  @@map("resource_permissions")
}

model ResourceVersion {
  id String @id @default(uuid()) @db.Uuid

  resourceId String           @db.Uuid
  resource   ExternalResource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  version            String
  checksum           String?
  sizeBytes          BigInt?
  modifiedByEmail    String?
  externalModifiedAt DateTime?
  metadata           Json?
  status             ExternalResourceStatus @default(ACTIVE)

  organizationId String @db.Uuid

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([resourceId, version])
  @@map("resource_versions")
}

model ConnectorLog {
  id String @id @default(uuid()) @db.Uuid

  connectorId String    @db.Uuid
  connector   Connector @relation(fields: [connectorId], references: [id], onDelete: Cascade)

  level   ConnectorLogLevel @default(INFO)
  // Namespaced event name: oauth.connected, sync.drive.completed, …
  event   String
  message String
  context Json?
  status  ConnectorStatus?

  organizationId String @db.Uuid

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([connectorId, createdAt])
  @@index([organizationId, level])
  @@map("connector_logs")
}

// ════════════════════════════════════════════════════════════════
// Phase 2 — Organizational Knowledge Engine
// Structured knowledge extracted from ingested documents: typed
// objects, relationships (the knowledge graph), aliases + mentions
// (entity resolution), versions, and a per-object timeline.
// ════════════════════════════════════════════════════════════════

enum KnowledgeObjectType {
  PERSON
  TEAM
  ORGANIZATION
  PROJECT
  TASK
  BUG
  ISSUE
  MEETING
  ACTION_ITEM
  DECISION
  DEADLINE
  FEATURE
  REQUIREMENT
  MILESTONE
  RISK
  QUESTION
  POLICY
  CUSTOMER
  VENDOR
  BOOKING
  PAYMENT
  INVOICE
  PRODUCT
  SERVICE
  LOCATION
  EMAIL
  CALENDAR_EVENT
  DOCUMENT
  FILE
  URL
  EVENT
  CONVERSATION
  COMMENT
  OTHER
}

enum KnowledgeObjectStatus {
  OPEN
  IN_PROGRESS
  BLOCKED
  RESOLVED
  COMPLETED
  CANCELLED
  ACTIVE
  ARCHIVED
  UNKNOWN
}

enum KnowledgePriority {
  CRITICAL
  HIGH
  MEDIUM
  LOW
  NONE
}

enum KnowledgeRelationshipType {
  ASSIGNED_TO
  REPORTED
  CREATED
  CREATES
  BELONGS_TO
  OWNS
  BLOCKS
  DEPENDS_ON
  MENTIONS
  LINKS_TO
  PART_OF
  ATTENDED
  WORKS_ON
  MANAGES
  RESOLVES
  AFFECTS
  SCHEDULED_FOR
  RESPONSIBLE_FOR
  RELATES_TO
  DUPLICATES
  // Phase 5 — Relationship Engine. Additive; the extractor + inference engine
  // use this fuller vocabulary. Near-synonyms of legacy values (e.g. CREATES /
  // CREATED_BY, DUPLICATES / DUPLICATE_OF, RELATES_TO / RELATED_TO) coexist so
  // existing rows never need rewriting.
  ASSIGNED_BY
  CREATED_BY
  REPORTED_BY
  MENTIONED_IN
  BLOCKED_BY
  GENERATED_FROM
  DISCUSSED_IN
  CREATED_IN
  UPDATED_IN
  REFERENCES
  ATTACHED_TO
  APPROVED_BY
  REQUESTED_BY
  COMPLETED_BY
  IMPLEMENTS
  FIXES
  USES
  CONNECTS_TO
  FOLLOWS
  PRECEDES
  SUPERSEDES
  PARENT_OF
  CHILD_OF
  DUPLICATE_OF
  RELATED_TO
}

enum TimelineEventType {
  CREATED
  UPDATED
  MENTIONED
  STATUS_CHANGED
  PRIORITY_CHANGED
  ASSIGNED
  RELATIONSHIP_ADDED
  CONFIDENCE_CHANGED
  MERGED
  RESTORED
  DELETED
}

model KnowledgeObject {
  id String @id @default(uuid()) @db.Uuid

  type            KnowledgeObjectType
  title           String
  // Lower-cased, whitespace/punctuation-normalized title for dedup lookups.
  normalizedTitle String
  summary         String?             @db.Text
  description     String?             @db.Text

  status     KnowledgeObjectStatus @default(UNKNOWN)
  priority   KnowledgePriority     @default(NONE)
  confidence Float                 @default(0.5)
  version    Int                   @default(1)

  // Provenance: where this object was first extracted from.
  sourceDocumentId String?   @db.Uuid
  sourceDocument   Document? @relation("KnowledgeObjectSource", fields: [sourceDocumentId], references: [id], onDelete: SetNull)
  sourceChunkId    String?   @db.Uuid
  createdBy        String? // "extraction:<provider>" or a user id

  // Type-specific extras (assignee email, amounts, dates, URLs, …).
  metadata Json?

  // Deduplication: when merged, this object is soft-deleted and points
  // at the surviving object.
  mergedIntoId String?           @db.Uuid
  mergedInto   KnowledgeObject?  @relation("KnowledgeMerge", fields: [mergedIntoId], references: [id], onDelete: SetNull)
  mergedFrom   KnowledgeObject[] @relation("KnowledgeMerge")

  organizationId String @db.Uuid

  aliases       EntityAlias[]
  mentions      EntityMention[]
  references    KnowledgeReference[]
  versions      KnowledgeVersion[]
  timeline      TimelineEvent[]
  tags          KnowledgeObjectTag[]
  relationsFrom KnowledgeRelationship[] @relation("KnowledgeRelFrom")
  relationsTo   KnowledgeRelationship[] @relation("KnowledgeRelTo")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([organizationId, type])
  @@index([organizationId, normalizedTitle])
  @@index([organizationId, status])
  @@index([sourceDocumentId])
  @@map("knowledge_objects")
}

model KnowledgeRelationship {
  id String @id @default(uuid()) @db.Uuid

  type KnowledgeRelationshipType

  fromId String          @db.Uuid
  from   KnowledgeObject @relation("KnowledgeRelFrom", fields: [fromId], references: [id], onDelete: Cascade)
  toId   String          @db.Uuid
  to     KnowledgeObject @relation("KnowledgeRelTo", fields: [toId], references: [id], onDelete: Cascade)

  confidence Float @default(0.5)

  // True when produced by the inference engine (2-hop rules) rather than
  // directly extracted/observed. Kept queryable so callers can trust-weight.
  isInferred Boolean @default(false)
  // Bumped each time reinforcing evidence updates the edge (confidence/merge).
  version    Int     @default(1)

  // Provenance of the evidence that produced this edge — full traceability.
  sourceDocumentId String? @db.Uuid
  sourceChunkId    String? @db.Uuid
  sourceMeetingId  String? @db.Uuid
  sourceEmailId    String?
  sourceUrl        String?
  // Short verbatim quote / transcript offset (ms) anchoring the evidence.
  evidenceSnippet  String? @db.Text
  transcriptMs     Int?
  metadata         Json?

  organizationId String @db.Uuid

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([fromId, toId, type])
  // Traversal + filtering indexes tuned for millions of edges.
  @@index([organizationId, fromId, type])
  @@index([organizationId, toId, type])
  @@index([organizationId, type])
  @@index([organizationId, isInferred])
  @@index([toId])
  @@map("knowledge_relationships")
}

model EntityAlias {
  id String @id @default(uuid()) @db.Uuid

  objectId String          @db.Uuid
  object   KnowledgeObject @relation(fields: [objectId], references: [id], onDelete: Cascade)

  alias           String
  normalizedAlias String
  // Where the alias came from: "extraction", "merge", "manual".
  source          String @default("extraction")
  confidence      Float  @default(1)

  organizationId String @db.Uuid

  createdAt DateTime @default(now())

  @@unique([objectId, normalizedAlias])
  @@index([organizationId, normalizedAlias])
  @@map("entity_aliases")
}

model EntityMention {
  id String @id @default(uuid()) @db.Uuid

  objectId String          @db.Uuid
  object   KnowledgeObject @relation(fields: [objectId], references: [id], onDelete: Cascade)

  documentId String   @db.Uuid
  document   Document @relation("KnowledgeMentions", fields: [documentId], references: [id], onDelete: Cascade)
  chunkId    String?  @db.Uuid
  // Short quote around the mention for display.
  snippet    String?  @db.Text
  confidence Float    @default(0.5)

  organizationId String @db.Uuid

  createdAt DateTime @default(now())

  @@index([objectId])
  @@index([documentId])
  @@index([organizationId])
  @@map("entity_mentions")
}

model TimelineEvent {
  id String @id @default(uuid()) @db.Uuid

  objectId String          @db.Uuid
  object   KnowledgeObject @relation(fields: [objectId], references: [id], onDelete: Cascade)

  type       TimelineEventType
  title      String?
  // Event-specific details (old/new status, merged object id, …).
  payload    Json?
  documentId String?           @db.Uuid
  actor      String?
  occurredAt DateTime          @default(now())

  organizationId String @db.Uuid

  createdAt DateTime @default(now())

  @@index([objectId, occurredAt])
  @@index([organizationId, occurredAt])
  @@map("timeline_events")
}

model KnowledgeTag {
  id String @id @default(uuid()) @db.Uuid

  name String
  slug String

  organizationId String @db.Uuid

  objects KnowledgeObjectTag[]

  createdAt DateTime @default(now())

  @@unique([organizationId, slug])
  @@map("knowledge_tags")
}

model KnowledgeObjectTag {
  objectId String          @db.Uuid
  object   KnowledgeObject @relation(fields: [objectId], references: [id], onDelete: Cascade)
  tagId    String          @db.Uuid
  tag      KnowledgeTag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([objectId, tagId])
  @@map("knowledge_object_tags")
}

model KnowledgeReference {
  id String @id @default(uuid()) @db.Uuid

  objectId String          @db.Uuid
  object   KnowledgeObject @relation(fields: [objectId], references: [id], onDelete: Cascade)

  // "document" | "chunk" | "url" | "external"
  kind       String
  documentId String? @db.Uuid
  chunkId    String? @db.Uuid
  url        String?
  label      String?

  organizationId String @db.Uuid

  createdAt DateTime @default(now())

  @@index([objectId])
  @@index([organizationId])
  @@map("knowledge_references")
}

model KnowledgeVersion {
  id String @id @default(uuid()) @db.Uuid

  objectId String          @db.Uuid
  object   KnowledgeObject @relation(fields: [objectId], references: [id], onDelete: Cascade)

  version    Int
  // Full snapshot of the object at this version.
  snapshot   Json
  // "created" | "updated" | "merged" | "restored" | "status_changed"
  changeType String
  changedBy  String?

  organizationId String @db.Uuid

  createdAt DateTime @default(now())

  @@unique([objectId, version])
  @@index([organizationId])
  @@map("knowledge_versions")
}

// ════════════════════════════════════════════════════════════════
// Phase 3 — Company Memory Engine
// Persistent, evolving organizational memory over time. Memory is the
// reconciled state of company knowledge — not chat history. Every new
// document, email, calendar event or knowledge change becomes a
// MemoryEvent that enriches an existing Memory instead of duplicating
// it, builds per-entity timelines, records conflicts across sources
// and maintains retrieval scores. Fully additive: like Phase 2, these
// tables carry `organizationId` and `entityId` as plain scalars
// (entityId → KnowledgeObject by convention) so no earlier model
// changes. Memory is the single source of truth for org history.
// ════════════════════════════════════════════════════════════════

enum MemoryType {
  SEMANTIC // Stable company facts
  EPISODIC // Events over time
  PROCEDURAL // Company processes
  WORKING // Recent context
  ORGANIZATIONAL // Cross-resource understanding
}

enum MemoryStatus {
  ACTIVE
  SUPERSEDED
  MERGED
  ARCHIVED
  EXPIRED
}

// Where a memory / event / observation originated.
enum MemorySource {
  DOCUMENT
  EMAIL
  CALENDAR
  MEETING
  KNOWLEDGE
  GIT
  SLACK
  MANUAL
  SYSTEM
}

// The kinds of events that create or enrich memory. `Future` sources are
// declared now so connectors can emit them without a schema change.
enum MemoryEventType {
  DOCUMENT_IMPORTED
  DOCUMENT_UPDATED
  EMAIL_RECEIVED
  CALENDAR_UPDATED
  KNOWLEDGE_OBJECT_CREATED
  KNOWLEDGE_OBJECT_UPDATED
  KNOWLEDGE_RELATIONSHIP_CHANGED
  MEETING_TRANSCRIPT
  GIT_COMMIT
  PULL_REQUEST
  SLACK_MESSAGE
}

enum MemoryEventStatus {
  PENDING
  PROCESSED
  FAILED
  SKIPPED
}

// Per-entity timeline event categories (a superset of the observed
// lifecycle: created → assigned → discussed → decided → resolved → released).
enum EntityTimelineEventType {
  CREATED
  ASSIGNED
  MENTIONED
  DISCUSSED
  STATUS_CHANGED
  PRIORITY_CHANGED
  DECISION_MADE
  UPDATED
  RELATIONSHIP_CHANGED
  RESOLVED
  RELEASED
  MERGED
  CONFLICT_DETECTED
  OTHER
}

enum ConflictStatus {
  OPEN
  AUTO_RESOLVED
  MANUALLY_RESOLVED
  DISMISSED
}

// How a conflicting attribute was (or should be) reconciled.
enum ConflictResolution {
  LATEST_WINS
  HIGHEST_CONFIDENCE
  SOURCE_PRIORITY
  MANUAL
}

// The evolving unit of organizational memory. Reconciliation guarantees at
// most one ACTIVE memory per (organizationId, memoryType, dedupeKey); new
// evidence bumps `version`, updates `summary`/`confidence` and appends a
// MemoryVersion + timeline event rather than inserting a duplicate.
model Memory {
  id String @id @default(uuid()) @db.Uuid

  memoryType MemoryType

  // Subject of the memory ("Payment timeout in booking flow"); normalized
  // form participates in the dedupe key.
  subject           String
  normalizedSubject String
  summary           String @db.Text
  // Deterministic reconciliation key: entityId (if any) else the
  // normalized subject, namespaced by memoryType. Unique among ACTIVE
  // memories so merges converge instead of duplicating.
  dedupeKey         String

  // The knowledge entity this memory is about (KnowledgeObject.id by
  // convention — plain scalar, no FK, mirroring Phase 2 child tables).
  entityId    String? @db.Uuid
  entityType  String?
  entityLabel String?

  confidence Float @default(0.5)
  importance Float @default(0.5)

  source  MemorySource
  status  MemoryStatus @default(ACTIVE)
  version Int          @default(1)

  // Temporal validity — memory is state over time.
  validFrom DateTime  @default(now())
  validTo   DateTime?

  // Provenance list: [{ kind, source, documentId, eventId, memoryId, label, at }].
  references Json?
  // Reconciled attribute values with provenance: { field: { value, source,
  // confidence, at } } — the current state this memory asserts.
  attributes Json?
  metadata   Json?

  // Reconciliation: a memory merged into another survivor.
  mergedIntoId String?  @db.Uuid
  mergedInto   Memory?  @relation("MemoryMerge", fields: [mergedIntoId], references: [id], onDelete: SetNull)
  mergedFrom   Memory[] @relation("MemoryMerge")

  organizationId String @db.Uuid

  versions  MemoryVersion[]
  events    MemoryEvent[]
  conflicts ConflictRecord[]
  score     MemoryScore?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([organizationId, memoryType, dedupeKey])
  @@index([organizationId, memoryType])
  @@index([organizationId, entityId])
  @@index([organizationId, status])
  @@index([organizationId, updatedAt])
  @@map("memories")
}

// Immutable snapshot of a memory at each version — the audit trail behind
// "what changed since last week" and "how did this evolve".
model MemoryVersion {
  id String @id @default(uuid()) @db.Uuid

  memoryId String @db.Uuid
  memory   Memory @relation(fields: [memoryId], references: [id], onDelete: Cascade)

  version       Int
  // Full memory state at this version.
  snapshot      Json
  // "created" | "updated" | "reconciled" | "merged" | "conflict" | "rescored"
  changeType    String
  // Short human diff, e.g. "confidence 0.6 → 0.8; status OPEN → RESOLVED".
  changeSummary String?
  changedBy     String?
  // The event that produced this version, if any.
  sourceEventId String? @db.Uuid

  organizationId String @db.Uuid

  createdAt DateTime @default(now())

  @@unique([memoryId, version])
  @@index([organizationId, createdAt])
  @@map("memory_versions")
}

// The inbound signal that drives memory. One row per observed change
// (document imported, email received, knowledge object updated, …).
// Processing is idempotent on (organizationId, dedupeHash).
model MemoryEvent {
  id String @id @default(uuid()) @db.Uuid

  type   MemoryEventType
  source MemorySource
  status MemoryEventStatus @default(PENDING)

  // Idempotency guard: hash of the semantic content of the event.
  dedupeHash String

  // Subject the event concerns; entityId resolved during processing.
  entityId   String? @db.Uuid
  entityHint String?
  documentId String? @db.Uuid
  externalId String?

  // Full event payload (title, summary, actor, attribute changes, snippet…).
  payload Json?

  occurredAt DateTime @default(now())

  // The memory this event was applied to (once processed).
  memoryId String? @db.Uuid
  memory   Memory? @relation(fields: [memoryId], references: [id], onDelete: SetNull)

  // Temporal linkage for observability.
  workflowId  String?
  processedAt DateTime?
  error       String?

  organizationId String @db.Uuid

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([organizationId, dedupeHash])
  @@index([organizationId, status])
  @@index([organizationId, occurredAt])
  @@index([entityId])
  @@map("memory_events")
}

// One timeline per entity — the automatically-built history container.
model MemoryTimeline {
  id String @id @default(uuid()) @db.Uuid

  // KnowledgeObject.id (plain scalar) or a synthetic subject key.
  entityId    String  @db.Uuid
  entityType  String?
  entityLabel String?
  summary     String?

  eventCount   Int       @default(0)
  firstEventAt DateTime?
  lastEventAt  DateTime?

  organizationId String @db.Uuid

  events MemoryTimelineEvent[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([organizationId, entityId])
  @@index([organizationId, lastEventAt])
  @@map("memory_timelines")
}

// A single, ordered, queryable moment in an entity's life. Deduplicated on
// (timelineId, dedupeHash) so replays never double-count.
model MemoryTimelineEvent {
  id String @id @default(uuid()) @db.Uuid

  timelineId String         @db.Uuid
  timeline   MemoryTimeline @relation(fields: [timelineId], references: [id], onDelete: Cascade)

  entityId    String                  @db.Uuid
  type        EntityTimelineEventType
  title       String
  description String?                 @db.Text
  source      MemorySource

  dedupeHash String

  // Cross-links back to the memory / event / document that produced it.
  memoryId   String? @db.Uuid
  eventId    String? @db.Uuid
  documentId String? @db.Uuid
  actor      String?
  confidence Float   @default(0.5)
  payload    Json?

  occurredAt DateTime @default(now())

  organizationId String @db.Uuid

  createdAt DateTime @default(now())

  @@unique([timelineId, dedupeHash])
  @@index([timelineId, occurredAt])
  @@index([organizationId, occurredAt])
  @@index([entityId, occurredAt])
  @@map("memory_timeline_events")
}

// Recorded disagreement between sources about one attribute of a memory.
// Keeps latest + previous values, confidence and provenance for manual
// review; auto-resolution stamps a resolution strategy.
model ConflictRecord {
  id String @id @default(uuid()) @db.Uuid

  memoryId String  @db.Uuid
  memory   Memory  @relation(fields: [memoryId], references: [id], onDelete: Cascade)
  entityId String? @db.Uuid

  // The disagreeing attribute, e.g. "status", "assignee", "priority".
  attribute String

  latestValue        Json
  previousValue      Json
  latestSource       MemorySource
  previousSource     MemorySource
  latestConfidence   Float        @default(0.5)
  previousConfidence Float        @default(0.5)
  latestAt           DateTime
  previousAt         DateTime

  status        ConflictStatus      @default(OPEN)
  resolution    ConflictResolution?
  resolvedValue Json?
  resolvedBy    String?
  resolvedAt    DateTime?

  organizationId String @db.Uuid

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([organizationId, status])
  @@index([memoryId])
  @@map("conflict_records")
}

// The reconciled, denormalized "current state" of an entity across all
// sources — the fast-path answer to "what is true about X right now".
model EntityState {
  id String @id @default(uuid()) @db.Uuid

  entityId   String  @db.Uuid
  entityType String?
  label      String?

  // { field: { value, source, confidence, at } } — winning values.
  currentState Json
  status       String?
  priority     String?
  assignee     String?

  lastEventAt DateTime?
  memoryCount Int       @default(0)
  version     Int       @default(1)

  organizationId String @db.Uuid

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([organizationId, entityId])
  @@index([organizationId, updatedAt])
  @@map("entity_states")
}

// Retrieval scores for a memory. Recomputed by MemoryScoringWorkflow;
// `composite` is the single number rankers sort on.
model MemoryScore {
  id String @id @default(uuid()) @db.Uuid

  memoryId String @unique @db.Uuid
  memory   Memory @relation(fields: [memoryId], references: [id], onDelete: Cascade)

  importance Float @default(0)
  freshness  Float @default(0)
  confidence Float @default(0)
  recency    Float @default(0)
  frequency  Float @default(0)
  composite  Float @default(0)

  // Raw frequency: how many events have reinforced this memory.
  frequencyCount Int      @default(1)
  computedAt     DateTime @default(now())

  organizationId String @db.Uuid

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, composite])
  @@map("memory_scores")
}

// ════════════════════════════════════════════════════════════════
// Phase 4 — Meeting Intelligence Platform
// Automatic capture and understanding of Google Meet calls. A Meeting is
// detected from a synced calendar event, auto-joined by a headless bot,
// transcribed locally (whisper.cpp) into TranscriptChunks, and mined by
// Gemini Flash into decisions, tasks, topics and participants that flow
// into the Phase 2 knowledge graph and Phase 3 memory engine. Like earlier
// phases every table is fully additive: `organizationId` and the cross-phase
// links (`connectorId`, `knowledgeObjectId`, `memoryId`, `resolvedEntityId`,
// `calendarEventExternalId`) are plain scalars with no FK to earlier models,
// so nothing above changes. Soft-delete + audit timestamps everywhere.
// ════════════════════════════════════════════════════════════════

enum MeetingStatus {
  SCHEDULED // detected, waiting for start
  JOINING // bot is opening the Meet
  WAITING // in the lobby, waiting to be admitted
  LIVE // admitted, capturing audio + transcribing
  PROCESSING // call ended, finalizing summary/knowledge
  COMPLETED // fully processed
  FAILED // could not join / capture / process
  CANCELLED // calendar event was cancelled
  MISSED // never joined (bot unavailable, no admission, …)
}

// Lifecycle of a single bot capture session for a meeting.
enum MeetingBotStatus {
  IDLE
  DISPATCHED
  JOINING
  WAITING_ADMISSION
  CAPTURING
  LEFT
  ERROR
}

enum MeetingItemStatus {
  OPEN
  IN_PROGRESS
  BLOCKED
  DONE
  CANCELLED
}

enum MeetingParticipantRole {
  HOST
  ATTENDEE
  BOT
}

// How a participant/decision/task was learned about.
enum MeetingItemSource {
  CALENDAR // known from the invite before the call
  TRANSCRIPT // extracted from what was said
  DETECTED // observed in the meeting UI (roster, captions)
}

model Meeting {
  id String @id @default(uuid()) @db.Uuid

  title       String
  description String?       @db.Text
  status      MeetingStatus @default(SCHEDULED)

  // The Google Meet join URL and the calendar event it came from
  // (ExternalResource.externalId by convention — plain scalars, no FK).
  meetUrl                 String
  connectorId             String? @db.Uuid
  calendarEventExternalId String?
  calendarId              String?
  organizerEmail          String?

  scheduledStart DateTime
  scheduledEnd   DateTime?
  actualStart    DateTime?
  actualEnd      DateTime?

  // Bot capture session state.
  botStatus    MeetingBotStatus @default(IDLE)
  botSessionId String?

  // Temporal linkage for observability + signalling the live workflow.
  workflowId String?
  runId      String?

  // Rolling counters kept in sync as the meeting streams, so lists and the
  // live UI never have to aggregate on read.
  chunkCount    Int @default(0)
  decisionCount Int @default(0)
  taskCount     Int @default(0)
  topicCount    Int @default(0)
  memoryCount   Int @default(0)

  error    String?
  metadata Json?

  organizationId String @db.Uuid

  transcriptChunks TranscriptChunk[]
  speakers         Speaker[]
  summary          MeetingSummary?
  decisions        MeetingDecision[]
  tasks            MeetingTask[]
  topics           MeetingTopic[]
  participants     MeetingParticipant[]
  memories         MeetingMemory[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([organizationId, meetUrl, scheduledStart])
  @@index([organizationId, status])
  @@index([organizationId, scheduledStart])
  @@index([workflowId])
  @@map("meetings")
}

model TranscriptChunk {
  id String @id @default(uuid()) @db.Uuid

  meetingId String  @db.Uuid
  meeting   Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  // Sequential index within the meeting; timestamps are milliseconds from
  // the start of capture.
  index   Int
  startMs Int
  endMs   Int
  text    String @db.Text

  // Optional speaker attribution (segmentation is future-ready).
  speakerId  String?  @db.Uuid
  speaker    Speaker? @relation(fields: [speakerId], references: [id], onDelete: SetNull)
  confidence Float    @default(0.5)

  // Set once the chunk has been mined for knowledge.
  processedAt DateTime?
  metadata    Json?

  organizationId String @db.Uuid

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([meetingId, index])
  @@index([meetingId, startMs])
  @@index([organizationId])
  @@map("transcript_chunks")
}

model Speaker {
  id String @id @default(uuid()) @db.Uuid

  meetingId String  @db.Uuid
  meeting   Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  // Diarization label ("Speaker 1") or a detected/known display name.
  label            String
  // Resolved KnowledgeObject (PERSON) id — plain scalar, no FK.
  resolvedEntityId String? @db.Uuid
  participantId    String? @db.Uuid

  transcriptChunks TranscriptChunk[]

  organizationId String @db.Uuid

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([meetingId, label])
  @@index([organizationId])
  @@map("speakers")
}

model MeetingSummary {
  id String @id @default(uuid()) @db.Uuid

  meetingId String  @unique @db.Uuid
  meeting   Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  executive String  @db.Text
  detailed  String  @db.Text
  // [{ text }] key points and [{ text, owner? }] follow-ups.
  keyPoints Json?
  followUps Json?
  sentiment String?

  // Provenance of the generated summary.
  model       String
  generatedAt DateTime @default(now())

  organizationId String @db.Uuid

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([organizationId])
  @@map("meeting_summaries")
}

model MeetingDecision {
  id String @id @default(uuid()) @db.Uuid

  meetingId String  @db.Uuid
  meeting   Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  title     String
  detail    String? @db.Text
  // Who made / owns the decision, and the reasoning if stated.
  owner     String?
  rationale String? @db.Text

  // Provenance + graph link (KnowledgeObject id, plain scalar).
  transcriptChunkId String?           @db.Uuid
  knowledgeObjectId String?           @db.Uuid
  source            MeetingItemSource @default(TRANSCRIPT)
  confidence        Float             @default(0.5)

  organizationId String @db.Uuid

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([meetingId])
  @@index([organizationId])
  @@map("meeting_decisions")
}

model MeetingTask {
  id String @id @default(uuid()) @db.Uuid

  meetingId String  @db.Uuid
  meeting   Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  title    String
  detail   String?           @db.Text
  owner    String?
  dueDate  DateTime?
  status   MeetingItemStatus @default(OPEN)
  // Reuses the shared knowledge priority scale.
  priority KnowledgePriority @default(NONE)

  transcriptChunkId String?           @db.Uuid
  knowledgeObjectId String?           @db.Uuid
  source            MeetingItemSource @default(TRANSCRIPT)
  confidence        Float             @default(0.5)

  organizationId String @db.Uuid

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([meetingId])
  @@index([organizationId, status])
  @@map("meeting_tasks")
}

model MeetingTopic {
  id String @id @default(uuid()) @db.Uuid

  meetingId String  @db.Uuid
  meeting   Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  title   String
  summary String? @db.Text
  // Coarse kind: topic | project | risk | blocker | bug | feature | idea —
  // classified by the extractor so one table holds all discussion threads.
  kind    String  @default("topic")

  transcriptChunkId String?           @db.Uuid
  knowledgeObjectId String?           @db.Uuid
  source            MeetingItemSource @default(TRANSCRIPT)
  confidence        Float             @default(0.5)

  organizationId String @db.Uuid

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([meetingId])
  @@index([organizationId, kind])
  @@map("meeting_topics")
}

model MeetingParticipant {
  id String @id @default(uuid()) @db.Uuid

  meetingId String  @db.Uuid
  meeting   Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  displayName String
  email       String?
  role        MeetingParticipantRole @default(ATTENDEE)
  source      MeetingItemSource      @default(CALENDAR)

  // Resolved KnowledgeObject (PERSON) id — plain scalar, no FK.
  resolvedEntityId String?   @db.Uuid
  joinedAt         DateTime?
  leftAt           DateTime?

  organizationId String @db.Uuid

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([meetingId, displayName, email])
  @@index([meetingId])
  @@index([organizationId])
  @@map("meeting_participants")
}

model MeetingMemory {
  id String @id @default(uuid()) @db.Uuid

  meetingId String  @db.Uuid
  meeting   Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  // Links to the memory this meeting produced (Memory.id / MemoryEvent.id /
  // KnowledgeObject.id — plain scalars, mirroring Phase 3 child tables).
  memoryId      String? @db.Uuid
  memoryEventId String? @db.Uuid
  entityId      String? @db.Uuid
  // "decision" | "task" | "topic" | "transcript" — what produced the memory.
  kind          String  @default("transcript")

  organizationId String @db.Uuid

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([meetingId])
  @@index([organizationId])
  @@index([memoryId])
  @@map("meeting_memories")
}
