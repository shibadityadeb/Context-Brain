# ── App ─────────────────────────────────────────────────────────
NODE_ENV=development
API_HOST=0.0.0.0
API_PORT=4000
API_CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=info

# ── Database (PostgreSQL) ───────────────────────────────────────
# Container maps to host port 5433 (5432 is often taken by a local Postgres).
DATABASE_URL=postgresql://brain:brain_dev_password@localhost:5433/company_brain?schema=public

# ── Redis ───────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── JWT ─────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long!!
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long!
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
COOKIE_SECRET=change-me-cookie-secret-min-32-chars-long!!

# ── Object Storage (MinIO / S3) ─────────────────────────────────
STORAGE_ENDPOINT=localhost
STORAGE_PORT=9000
STORAGE_USE_SSL=false
STORAGE_ACCESS_KEY=brain_minio
STORAGE_SECRET_KEY=brain_minio_password
STORAGE_DEFAULT_BUCKET=company-brain

# ── Vector DB (Qdrant) ──────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ── Queue (BullMQ) ──────────────────────────────────────────────
QUEUE_PREFIX=brain

# ── Temporal (workflow orchestration) ───────────────────────────
# Server gRPC endpoint; UI at http://localhost:8233
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=company-brain
TEMPORAL_TASK_QUEUE=brain-core
# Port for the temporal-worker's local health/status endpoint.
TEMPORAL_WORKER_HEALTH_PORT=4100

# ── Embeddings (knowledge pipeline) ─────────────────────────────
# Provider: local (offline, dev default) | openai | gemini | voyage
EMBEDDINGS_PROVIDER=local
# EMBEDDINGS_MODEL=text-embedding-3-small
# EMBEDDINGS_DIMENSION=384
# OPENAI_API_KEY=
# GEMINI_API_KEY=
# VOYAGE_API_KEY=

# ── Chunking ────────────────────────────────────────────────────
CHUNK_SIZE=400
CHUNK_OVERLAP=60

# ── Company Memory Engine (Phase 3) ─────────────────────────────
# All optional — documented defaults live in @company-brain/memory-engine.
# Uncomment only to override. Nothing operational is frozen in code.
# MEMORY_FRESHNESS_HALFLIFE_DAYS=14
# MEMORY_RECENCY_HALFLIFE_DAYS=7
# MEMORY_FREQUENCY_SATURATION=10
# MEMORY_CONFLICT_STRATEGY=LATEST_WINS   # HIGHEST_CONFIDENCE | SOURCE_PRIORITY | MANUAL
# MEMORY_CONFLICT_CONFIDENCE_DELTA=0.15
# MEMORY_CONFLICT_TRUST_DELTA=0.15
# MEMORY_DEFAULT_ATTRIBUTE_CONFIDENCE=0.6
# MEMORY_WORKING_TTL_DAYS=30
# MEMORY_SUPERSEDED_TTL_DAYS=180
# MEMORY_MAX_OBJECTS_PER_RUN=500
# MEMORY_MAX_EVENTS_PER_APPLY=1000
# MEMORY_MAX_MENTIONS_PER_OBJECT=50
# MEMORY_SCORE_WEIGHTS={"importance":0.3,"confidence":0.2,"freshness":0.2,"recency":0.15,"frequency":0.15}

# ── Connectors (Google Workspace OAuth) ─────────────────────────
# Create OAuth client (Web application) at console.cloud.google.com,
# authorized redirect URI = GOOGLE_REDIRECT_URI below.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/api/v1/auth/google/callback
# Refresh-token encryption at rest. Generate: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=change-me-generate-with-openssl-rand-hex-32
CONNECTOR_TASK_QUEUE=brain-connectors
CONNECTOR_WORKER_HEALTH_PORT=4101

# ── Meeting Intelligence (Phase 4) ──────────────────────────────
# Auto-join Google Meets, transcribe locally (whisper.cpp), extract with
# Gemini Flash. The capture bot runs in Docker (Linux-only). Documented
# defaults live in @company-brain/meeting-engine — override only to tune.
MEETING_TASK_QUEUE=brain-meetings
MEETING_WORKER_HEALTH_PORT=4102
# Where the meeting-worker + API reach the bot's control API.
MEETING_BOT_URL=http://localhost:4200
# Base URL the bot calls back on. Use host.docker.internal when the bot runs
# in Docker and the API runs on the host.
API_BASE_URL=http://localhost:4000
# Shared secret between API, meeting-worker and the bot. openssl rand -hex 24
MEETING_INTERNAL_TOKEN=dev-meeting-internal-token
# Transcript extraction LLM (spec: Gemini Flash free tier). Falls back to
# EXTRACTION_PROVIDER when unset; needs GEMINI_API_KEY.
# MEETING_EXTRACTION_PROVIDER=gemini
# MEETING_EXTRACTION_MODEL=gemini-flash-latest
# whisper.cpp model — base.en today; rebuild the bot image for medium.
# MEETING_WHISPER_MODEL=base.en
# MEETING_CHUNK_SECONDS=30
# MEETING_JOIN_LEAD_SECONDS=60
# MEETING_LOOKAHEAD_SECONDS=86400
# MEETING_ADMISSION_TIMEOUT_SECONDS=300
# MEETING_SILENCE_TIMEOUT_SECONDS=900
# MEETING_MAX_SECONDS=14400
# MEETING_BOT_DISPLAY_NAME=Company Brain Notetaker
# Bot audio capture window (seconds per whisper pass).
# BOT_CAPTURE_WINDOW_SECONDS=12

# ── LLM layer (@company-brain/llm) ──────────────────────────────
# Backend the provider factory builds. Only "codex" is wired today;
# openai/claude/ollama/vllm are reserved extension points.
LLM_PROVIDER=codex
# Codex CLI adapter (development LLM backend). Callers never see these —
# they depend on the LLMProvider interface only.
CODEX_BINARY=codex
# Args before the prompt (streamed over stdin). Add flags as needed, e.g.
# "exec --full-auto".
CODEX_ARGS=exec
# Per-attempt wall-clock timeout (ms).
CODEX_TIMEOUT=180000
# Additional attempts on retryable failures.
CODEX_RETRIES=2
# Base backoff between retries (ms); grows exponentially.
CODEX_RETRY_DELAY=1000
# Per-call input budget (chars, ~4 chars/token). Transcripts above this are
# hierarchically chunk-summarized then re-analyzed so no single call overflows.
CODEX_MAX_PROMPT_CHARS=24000
# Max Codex processes in flight when fanning out over chunks (protects the host
# on brain-sized corpora / long meetings).
CODEX_MAX_CONCURRENCY=4
# Safety cap on recursive summarize-of-summaries passes.
CODEX_MAX_REDUCE_DEPTH=5
# CODEX_CWD=

# ── Frontend ────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
