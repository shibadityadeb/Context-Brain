# ── Meeting bot configuration ────────────────────────────────────────────────
# Every value is optional and has a config-driven default; nothing operational
# is hardcoded in the source. Anonymous ("ask to join") works without an account;
# provide credentials only if you want the bot to join as a signed-in user.

NODE_ENV=development
LOG_LEVEL=info

# Dedicated Google account the bot signs in as (optional — leave blank to join
# anonymously as a guest). Never commit real credentials.
GOOGLE_EMAIL=
GOOGLE_PASSWORD=

# Persistent Chrome user-data dir. Keeping this stable means the Google login
# survives restarts — the bot does not log in before every meeting.
CHROME_PROFILE=./.meeting-bot/profile

# Where recordings + meeting metadata are written.
RECORDING_DIRECTORY=./.meeting-bot/recordings

# Run Chrome headful (false) or headless (true). Headful is more reliable for
# Meet; headless needs a virtual display for audio to render.
HEADLESS=false

# Display name shown in the call when joining anonymously.
DISPLAY_NAME=Company Brain Notetaker

# ── Timeouts & polling (milliseconds unless *_SECONDS) ────────────────────────
ADMISSION_TIMEOUT_SECONDS=300
MAX_MEETING_SECONDS=14400
EMPTY_MEETING_SECONDS=120
PAGE_LOAD_TIMEOUT_MS=60000
ADMISSION_POLL_MS=3000
PARTICIPANT_POLL_MS=5000
END_POLL_MS=5000

# ── Resilience ────────────────────────────────────────────────────────────────
JOIN_RETRY_ATTEMPTS=3
JOIN_RETRY_BACKOFF_MS=5000
BROWSER_RESTART_ATTEMPTS=3

# ── Calendar auto-join (watch the user's Google Calendar) ─────────────────────
# The bot discovers Meet events on the user's calendar and joins automatically.
# It reuses the OAuth access the Context Brain already holds (calendar.readonly);
# no separate credentials here. For a quick manual CLI test only, you can pass a
# short-lived token via GOOGLE_ACCESS_TOKEN.
CALENDAR_ID=primary
CALENDAR_POLL_SECONDS=60
CALENDAR_LOOKAHEAD_MINUTES=1440
CALENDAR_JOIN_LEAD_SECONDS=30
# any | accepted | organizer
CALENDAR_JOIN_POLICY=any
